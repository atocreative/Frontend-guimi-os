generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  jobTitle  String?
  role      Role     @default(COLABORADOR)
  avatarUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]   @relation("LeadOwner")
  tasks     Task[]
}

model Lead {
  id             String      @id @default(cuid())
  kommoId        String?     @unique
  name           String
  phone          String?
  email          String?
  stage          String
  temperature    Temperature @default(MORNO)
  origin         String?
  value          Float?
  lastContactAt  DateTime?
  nextFollowUpAt DateTime?
  stoppedAt      DateTime?
  convertedAt    DateTime?
  lostAt         DateTime?
  lostReason     String?
  ownerId        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  syncedAt       DateTime?
  owner          User?       @relation("LeadOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([stage])
}

model Sale {
  id          String    @id @default(cuid())
  foneNinjaId String?   @unique
  leadId      String?
  product     String
  category    String?
  saleValue   Float
  costValue   Float?
  grossProfit Float?
  paymentType String?
  soldAt      DateTime
  sellerName  String?
  createdAt   DateTime  @default(now())
  syncedAt    DateTime?
}

model Expense {
  id            String    @id @default(cuid())
  meuAssessorId String?   @unique
  description   String
  category      String
  amount        Float
  dueAt         DateTime
  paidAt        DateTime?
  paid          Boolean   @default(false)
  createdAt     DateTime  @default(now())
  syncedAt      DateTime?
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDENTE)
  priority    Priority?
  dueAt       DateTime?
  horario     String?
  completedAt DateTime?
  assigneeId  String?
  relatedTo   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  assignee    User?      @relation(fields: [assigneeId], references: [id])

  @@index([assigneeId])
  @@index([status])
  @@index([status, assigneeId])
}

model FinancialSnapshot {
  id           String   @id @default(cuid())
  date         DateTime @unique
  totalRevenue Float
  totalExpense Float
  grossProfit  Float
  netProfit    Float?
  margin       Float?
  cashBalance  Float?
  createdAt    DateTime @default(now())
}

model SyncLog {
  id         String     @id @default(cuid())
  source     String
  status     SyncStatus
  recordsIn  Int        @default(0)
  recordsOut Int        @default(0)
  error      String?
  startedAt  DateTime   @default(now())
  finishedAt DateTime?
}

enum Role {
  ADMIN
  GESTOR
  COLABORADOR
}

enum Temperature {
  QUENTE
  MORNO
  FRIO
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum Priority {
  ALTA
  MEDIA
  BAIXA
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum ChecklistTipo {
  ABERTURA
  FECHAMENTO
}

model ChecklistItem {
  id          String        @id @default(cuid())
  titulo      String
  descricao   String?
  tipo        ChecklistTipo
  responsavel String
  horario     String?
  ordem       Int           @default(0)
  concluido   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tipo])
}
